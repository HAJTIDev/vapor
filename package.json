{
  "name": "vapor",
  "version": "1.4.8",
  "description": "A minimal DRM-free game launcher",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "node scripts/encrypt-key.js && vite build && electron-builder",
    "build:key": "node scripts/encrypt-key.js",
    "preview": "vite preview",
    "publish": "node scripts/publish.mjs",
    "push": "git add . && git commit -m meow && git push"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "webtorrent": "^2.8.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.vapor.launcher",
    "productName": "Vapor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "main/**/*",
      "preload.js",
      ".env"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/sgdb.enc.json",
        "to": "sgdb.enc.json",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerSidebar": "build/sidebar.bmp"
    },
    "publish": {
      "provider": "github",
      "owner": "HAJTIDev",
      "repo": "vapor"
    }
  }
}
